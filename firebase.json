{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "target": "libra-vaultx",
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/node/**",
        "function": "nodeApi"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
